{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FreeUltraCode",
  "version": "0.3.4",
  "identifier": "com.freeultracode.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FreeUltraCode",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../cli/dist/fuc.mjs": "cli/fuc.mjs",
      "resources/workflows/deep-research/WORKFLOW.md": "workflows/deep-research/WORKFLOW.md",
      "resources/workflows/deep-research/protocol/model-agnostic-deep-research.md": "workflows/deep-research/protocol/model-agnostic-deep-research.md",
      "resources/workflows/deep-research/protocol/README.md": "workflows/deep-research/protocol/README.md"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
